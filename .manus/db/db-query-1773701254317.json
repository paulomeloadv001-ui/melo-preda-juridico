{
  "query": "SELECT c.id, c.nomeCompleto, c.cpfCnpj, c.createdAt, \n  (SELECT COUNT(*) FROM processos p WHERE p.clienteId = c.id) as totalProcessos,\n  (SELECT COUNT(*) FROM movimentacoes m JOIN processos p2 ON m.processoId = p2.id WHERE p2.clienteId = c.id) as totalMovimentacoes,\n  (SELECT COUNT(*) FROM partes_processuais pp JOIN processos p3 ON pp.processoId = p3.id WHERE p3.clienteId = c.id) as totalPartes,\n  (SELECT COUNT(*) FROM estrategias ep JOIN processos p4 ON ep.processoId = p4.id WHERE p4.clienteId = c.id) as totalEstrategias,\n  (SELECT COUNT(*) FROM documentos d WHERE d.clienteId = c.id) as totalDocumentos\nFROM clientes c ORDER BY c.nomeCompleto;",
